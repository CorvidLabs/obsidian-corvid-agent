{
	"name": "obsidian-corvid-agent",
	"version": "0.2.0",
	"description": "AI chat plugin for Obsidian — supports Ollama, Claude, OpenAI, and corvid-agent backends",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"spec:check": "bash scripts/specsync.sh check",
		"spec:check:strict": "bash scripts/specsync.sh check --strict",
		"spec:coverage": "bash scripts/specsync.sh coverage",
		"spec:score": "bash scripts/specsync.sh score"
	},
	"keywords": ["obsidian", "ai", "ollama", "claude", "openai", "corvid-agent", "chat"],
	"author": "CorvidLabs",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.24.0",
		"obsidian": "^1.7.2",
		"typescript": "^5.7.0"
	}
}
